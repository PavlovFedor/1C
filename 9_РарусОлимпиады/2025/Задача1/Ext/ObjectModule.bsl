// По вызову данной процедуры ответ должен
// быть записан в регистр выходных данных
Процедура ВыполнитьЗадачу() Экспорт
   
    // 1. Получаем данные из входного регистра
    Выборка = ПолучитьВходныеДанные();
    Если Выборка = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // 2. Проверяем корректность данных
    Если Не ПроверитьКорректностьДанных(Выборка) Тогда
        Сообщить("Обнаружены ошибки в исходных данных. Обработка прервана.");
        Возврат;
    КонецЕсли;
    
    // 3. Выполняем расчеты
    РезультатыРасчета = ВыполнитьРасчеты(Выборка);
    Если РезультатыРасчета = Неопределено Тогда
        Сообщить("Ошибка при выполнении расчетов.");
        Возврат;
    КонецЕсли;
    
    // 4. Записываем результаты в выходной регистр
    Если Не ЗаписатьРезультаты(РезультатыРасчета) Тогда
        Сообщить("Ошибка при записи результатов.");
        Возврат;
    КонецЕсли;
    
    Сообщение = Новый СообщениеПользователю;
    Сообщение.Текст = "Задача выполнена успешно!";
    Сообщение.Сообщить();
    
КонецПроцедуры

// 1. Функция получения данных из регистра
Функция ПолучитьВходныеДанные()
    
    Попытка
        Запрос = Новый Запрос;  
        Запрос.Текст = "ВЫБРАТЬ
        |	ВВОД_Задача1.НомерКолесика,
        |	ВВОД_Задача1.НаибольшаяЦифра ,
        |	ВВОД_Задача1.ПозицийЗаПоворот,
        |	ВВОД_Задача1.НачальнаяЦифра,
        |	ВВОД_Задача1.КонечнаяЦифра
        |ИЗ
        |	РегистрСведений.ВВОД_Задача1 КАК ВВОД_Задача1";
        
        РезультатЗапроса = Запрос.Выполнить();
        Выборка = РезультатЗапроса.Выбрать();
        
        Если НЕ Выборка.Количество() > 0 Тогда
            Сообщить("Входной регистр не содержит данных для обработки.");
            Возврат Неопределено;
        КонецЕсли;
        
        Возврат Выборка;
        
    Исключение
        Сообщить("Ошибка при получении данных из регистра: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции

// 2. Функция проверки корректности данных
Функция ПроверитьКорректностьДанных(Выборка)
    
    // Сбрасываем выборку и проходим по ней для проверки
    Выборка.Сбросить();
    
    Пока Выборка.Следующий() Цикл
        
        // Проверка КоличестваКосмонавтов
        Если НЕ ПроверитьПоле(Выборка.НомерКолесика, 100000) Тогда
            Сообщить("Ошибка: поле 'НомерКолесика' содержит некорректные данные");
            Возврат Ложь;
        КонецЕсли;
        
        // Проверка КоличестваРастений
        Если НЕ ПроверитьПоле(Выборка.НаибольшаяЦифра, 9) Тогда
            Сообщить("Ошибка: поле 'НаибольшаяЦифра' содержит некорректные данные");
            Возврат Ложь;
        КонецЕсли;
        
        // Проверка ГрузоподъемностиРакеты
        Если НЕ ПроверитьПоле(Выборка.ПозицийЗаПоворот, 9) Тогда
            Сообщить("Ошибка: поле 'ПозицийЗаПоворот' содержит некорректные данные");
            Возврат Ложь;
		КонецЕсли;
		
        // Проверка ГрузоподъемностиРакеты
        Если НЕ ПроверитьПоле(Выборка.НачальнаяЦифра, 9) Тогда
            Сообщить("Ошибка: поле 'НачальнаяЦифра' содержит некорректные данные");
            Возврат Ложь;
		КонецЕсли;
		
        // Проверка ГрузоподъемностиРакеты
        Если НЕ ПроверитьПоле(Выборка.КонечнаяЦифра, 9) Тогда
            Сообщить("Ошибка: поле 'КонечнаяЦифра' содержит некорректные данные");
            Возврат Ложь;
        КонецЕсли;
        
    КонецЦикла;
    
    // Сбрасываем выборку обратно для дальнейшего использования
    Выборка.Сбросить();
    
    Возврат Истина;
    
КонецФункции

// 2.1 Функция проверки одного поля
Функция ПроверитьПоле(Знач Значение, Знач ВерхнийПредел)
    
    // Проверка типа данных - является ли числом
    Если ТипЗнч(Значение) <> Тип("Число") Тогда
        Возврат Ложь;
    КонецЕсли;
    
    // Проверка диапазона от 0 до ВерхнийПредел
    Если Значение < 0 ИЛИ Значение > ВерхнийПредел Тогда
        Возврат Ложь;
    КонецЕсли;
    
    Возврат Истина;
    
КонецФункции   

// 3. Функция выполнения расчетов
Функция ВыполнитьРасчеты(Выборка)
    
    Попытка
        Результаты = Новый Массив;
		
		// Сбрасываем выборку перед использованием
        Выборка.Сбросить();
		
		СуммарноеКоличествоПоворотов = 0;	
        Пока Выборка.Следующий() Цикл 
            СуммарноеКоличествоПоворотов = СуммарноеКоличествоПоворотов + ВычислитьМинКолвоПоворотов(
                Выборка.НомерКолесика, 
                Выборка.НаибольшаяЦифра, 
                Выборка.ПозицийЗаПоворот,                  
                Выборка.НачальнаяЦифра,                
                Выборка.КонечнаяЦифра
            );
        КонецЦикла;
                    // Создаем структуру для хранения результата
            Результат = Новый Структура;
            Результат.Вставить("СуммарноеКоличествоПоворотов", СуммарноеКоличествоПоворотов);
            
            Результаты.Добавить(Результат);
        Возврат Результаты;
        
    Исключение
        Сообщить("Ошибка при выполнении расчетов: " + ОписаниеОшибки());
        Возврат Неопределено;
    КонецПопытки;
    
КонецФункции

// 3.1 Вспомогательная функция для преобразования данных
Функция ВычислитьМинКолвоПоворотов(Знач НомерКолесика, Знач НаибольшаяЦифра, Знач ПозицийЗаПоворот, Знач НачальнаяЦифра, Знач КонечнаяЦифра)
    
    //Инициализируем данные
    МинКолвоПоворотов = 0;                                
	
	КрутимВверхПозиция = НачальнаяЦифра;
	КрутимВнизПозиция = НачальнаяЦифра;
	
	КолвоПоворотовВниз = 0;
	КолвоПоворотовВверх = 0;
	                                
    Пока НЕ НужноеЛиЧисло(КрутимВнизПозиция,КонечнаяЦифра) И НЕ НужноеЛиЧисло(КрутимВверхПозиция,КонечнаяЦифра) Цикл
		
		Если НЕ НужноеЛиЧисло(КрутимВнизПозиция,КонечнаяЦифра) Тогда
			КрутимВнизПозиция = КрутимВниз(КрутимВнизПозиция, НаибольшаяЦифра, ПозицийЗаПоворот);
			КолвоПоворотовВниз = КолвоПоворотовВниз + 1;  	
		КонецЕсли; 
		
		Если НЕ НужноеЛиЧисло(КрутимВверхПозиция,КонечнаяЦифра) Тогда  
			КрутимВверхПозиция = КрутимВверх(КрутимВверхПозиция, НаибольшаяЦифра, ПозицийЗаПоворот);
			КолвоПоворотовВверх = КолвоПоворотовВверх + 1;  	
		КонецЕсли;
		
		Сообщить("НомерКолесика:" + НомерКолесика + " Вверх: " + КолвоПоворотовВверх + " Позиция: " + КрутимВверхПозиция + " Вниз: " + КолвоПоворотовВниз + " Позиция: " + КрутимВнизПозиция);
		
     КонецЦикла;  
	 
	 Если КолвоПоворотовВниз < КолвоПоворотовВверх Тогда
    	Возврат КолвоПоворотовВниз;
	 Иначе
        Возврат КолвоПоворотовВверх;
	 КонецЕсли;
КонецФункции
//3.1
Функция НужноеЛиЧисло(Знач ЧислоДляПроверки, Знач НужноеЧисло)
	Если ЧислоДляПроверки <> НужноеЧисло Тогда
		Возврат	Ложь;  
	Иначе
		Возврат Истина;    	
	КонецЕсли;     
КонецФункции

//3.2
Функция КрутимВниз(Знач ИсходнаяПозиция, Знач НаибольшаяЦифра, Знач ПозицийЗаПоворот)
	Прокрут = ПозицийЗаПоворот;
	ТекущаяПозиция = ИсходнаяПозиция;
	
	Пока Прокрут <> 0 Цикл  
		Если ТекущаяПозиция <> 0 Тогда
			ТекущаяПозиция = ТекущаяПозиция - 1;
		Иначе
			ТекущаяПозиция = НаибольшаяЦифра 
		КонецЕсли;
			
		Прокрут = Прокрут-1;		
	КонецЦикла;
	
	Возврат ТекущаяПозиция;	
КонецФункции

//3.3
Функция КрутимВверх(Знач ИсходнаяПозиция, Знач НаибольшаяЦифра, Знач ПозицийЗаПоворот)
	Прокрут = ПозицийЗаПоворот;
	ТекущаяПозиция = ИсходнаяПозиция;
	
	Пока Прокрут <> 0 Цикл  
		Если ТекущаяПозиция <> НаибольшаяЦифра Тогда
			ТекущаяПозиция = ТекущаяПозиция + 1;
		Иначе
			ТекущаяПозиция = 0 
		КонецЕсли;
			
		Прокрут = Прокрут-1;		
	КонецЦикла;
	
	Возврат ТекущаяПозиция;	
КонецФункции


// 4. Функция записи результатов в регистр
Функция ЗаписатьРезультаты(РезультатыРасчета)
    
    Попытка
        НаборЗаписей = РегистрыСведений.ВЫВОД_Задача1.СоздатьНаборЗаписей();
        
        Для Каждого Результат Из РезультатыРасчета Цикл
            Запись = НаборЗаписей.Добавить();
            Запись.СуммарноеКоличествоПоворотов = Результат.СуммарноеКоличествоПоворотов;
        КонецЦикла;
        
        НаборЗаписей.Записать();
        Возврат Истина;
        
    Исключение
        Сообщить("Ошибка при записи в регистр: " + ОписаниеОшибки());
        Возврат Ложь;
    КонецПопытки;
    
КонецФункции